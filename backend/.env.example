# =============================================================================
# HCRM Backend — mẫu biến môi trường (copy nội dung đã điền vào Dokploy → Environment)
# Không commit file .env thật. Sửa giá trị placeholder trước khi dùng.
# =============================================================================

# --- Bắt buộc ---
# PostgreSQL connection string (Prisma).
# Định dạng: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Lưu ý: chỉ MỘT dấu @ ngăn cách (user:pass) và host. Nếu mật khẩu có ký tự đặc biệt (@, :, #, …) phải URL-encode (ví dụ @ → %40).
# CẢNH BÁO: Một số UI (Dokploy) hiển thị chuỗi dạng ...matkhau@@host... — đó là SAI; phải là ...matkhau%40@host... (không được hai @ liên tiếp).
# Docker / Dokploy: HOST phải là tên service Postgres trong cùng network (DNS nội bộ), không phải localhost trên máy dev — nếu sai sẽ lỗi Prisma P1001 (Can't reach database server).
DATABASE_URL=postgresql://app_user:YOUR_PASSWORD@hcrm-database-chl366:5432/app_db

NODE_ENV=production
PORT=3000

# JWT ký cookie/token — dùng chuỗi ngẫu nhiên dài, KHÁC nhau mỗi môi trường
JWT_SECRET=change_me_to_a_long_random_secret

# URL công khai của API (embed form lead, link tuyệt đối). Ví dụ: https://crm.kagri.tech/api
API_BASE_URL=https://your-domain.example/api

# --- Web Push (tùy chọn; bỏ trống nếu chưa dùng) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:support@kagri.tech

# --- Viettel Post (tùy chọn) ---
VTP_API_URL=https://partner.viettelpost.vn/v2
VTP_USERNAME=
VTP_PASSWORD=
# Token API (nếu có; có thể lấy qua script / đăng nhập VTP)
VTP_TOKEN=
# Xác thực webhook cập nhật trạng thái vận chuyển (public /api/webhook/viettel-post/...)
VTP_WEBHOOK_SECRET=

# Địa chỉ gửi: ứng dụng HCRM lấy từ kho (warehouses) đã chọn trên đơn — KHÔNG đọc các biến dưới khi tính cước / đẩy VTP.
# (Có thể giữ cho script thử nghiệm tay / Postman.)
# VTP_SENDER_PROVINCE=
# VTP_SENDER_DISTRICT=
# VTP_SENDER_WARD=
# VTP_SENDER_NAME=
# VTP_SENDER_PHONE=
# VTP_SENDER_ADDRESS=
# Mã dịch vụ khi gọi createOrder (VD: LCOD, VCN). Để trống → backend gọi getPriceAll và chọn VCN nếu có, không thì dịch vụ đầu tiên.
VTP_ORDER_SERVICE=
# Script npm run test:vtp-order — ghi đè điểm nhận (mặc định script dùng mẫu HN→TP.HCM).
# VTP_TEST_RECEIVER_PROVINCE=
# VTP_TEST_RECEIVER_DISTRICT=
# VTP_TEST_RECEIVER_WARD=
# VTP_TEST_USE_DB_RECEIVER=

# Alias tương thích (nếu đã dùng tên cũ)
# VIETTEL_POST_API_URL=
# VIETTEL_POST_USERNAME=
# VIETTEL_POST_PASSWORD=
# VIETTEL_POST_TOKEN=

# --- Hóa đơn / thông tin công ty (Kế toán — tùy chọn) ---
COMPANY_TAX_CODE=
COMPANY_NAME=Công ty TNHH Kagri Tech
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=

# --- File upload (thư mục backend/uploads, phục vụ /uploads/...) ---
# Giới hạn kích thước một file upload (byte). Mặc định trong code: 20971520 (20MB).
MAX_UPLOAD_BYTES=20971520
# Token tích hợp proxy tùy chỉnh (tùy chọn); backend HCRM không bắt buộc đọc biến này.
API_TOKEN=

# =============================================================================
# Frontend build (Vite) — thường set tại BƯỚC BUILD Docker/Dokploy, không phải runtime Node
# Nếu backend serve sẵn frontend/dist và trình duyệt gọi cùng origin, có thể để trống hoặc /api
# =============================================================================
# VITE_API_URL=/api
# VITE_GOOGLE_MAPS_API_KEY=
