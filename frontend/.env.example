# CRM Frontend Environment Variables

# API Backend URL
VITE_API_URL=http://localhost:5000/api

# Google Maps API Key (optional)
# Để sử dụng Google Maps Embed API trên Dashboard
# Đăng ký tại: https://console.cloud.google.com/google/maps-apis
# Maps Embed API là MIỄN PHÍ và không giới hạn số lần sử dụng
# Tham số region=VN sẽ hiển thị bản đồ theo quan điểm chủ quyền Việt Nam
VITE_GOOGLE_MAPS_API_KEY=

# Nếu không có API key, hệ thống sẽ tự động sử dụng bản đồ SVG Việt Nam
