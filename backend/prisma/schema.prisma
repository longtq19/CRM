model EmployeePerformance {
  id                  String   @id @default(uuid())
  employeeId          String   @map("employee_id")
  date                DateTime @db.Date
  leadsCreated        Int      @default(0) @map("leads_created")
  leadsConverted      Int      @default(0) @map("leads_converted")
  marketingRevenue    Decimal  @default(0) @map("marketing_revenue") @db.Decimal(18, 2)
  customersContacted  Int      @default(0) @map("customers_contacted")
  ordersCreated       Int      @default(0) @map("orders_created")
  salesRevenue        Decimal  @default(0) @map("sales_revenue") @db.Decimal(18, 2)
  customersFollowedUp Int      @default(0) @map("customers_followed_up")
  repeatOrders        Int      @default(0) @map("repeat_orders")
  resalesRevenue      Decimal  @default(0) @map("resales_revenue") @db.Decimal(18, 2)
  totalRevenue        Decimal  @default(0) @map("total_revenue") @db.Decimal(18, 2)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @map("updated_at")

  @@unique([employeeId, date])
  @@index([date])
  @@index([employeeId])
  @@map("employee_performances")
}

model InventoryLog {
  id          String   @id @default(uuid())
  productId   String   @map("product_id")
  batchId     String?  @map("batch_id")
  type        String
  quantity    Int
  previousQty Int      @map("previous_qty")
  newQty      Int      @map("new_qty")
  orderId     String?  @map("order_id")
  reason      String
  note        String?
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([productId])
  @@index([type])
  @@map("inventory_logs")
}

model LeaveRequest {
  id                   String             @id @default(uuid())
  code                 String             @unique
  employeeId           String             @map("employee_id")
  leaveType             LeaveType          @default(ANNUAL) @map("leave_type")
  leaveTypeOtherLabel   String?          @map("leave_type_other_label") @db.VarChar(200) // OTHER: tên loại do NV nhập
  startDate            DateTime           @map("start_date")
  endDate              DateTime           @map("end_date")
  totalDays            Float              @map("total_days")
  reason               String?
  status       LeaveRequestStatus @default(PENDING)
  approverId   String?            @map("approver_id")
  approvedAt   DateTime?          @map("approved_at")
  rejectedAt   DateTime?          @map("rejected_at")
  approverNote String?            @map("approver_note")
  confirmerId  String?            @map("confirmer_id")
  confirmedAt  DateTime?          @map("confirmed_at")
  hrNote       String?            @map("hr_note")
  lateMinutes  Int?               @default(0) @map("late_minutes")
  earlyMinutes Int?               @default(0) @map("early_minutes")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  approver     Employee?          @relation("leave_requests_approver_idToemployees", fields: [approverId], references: [id])
  confirmer    Employee?          @relation("leave_requests_confirmer_idToemployees", fields: [confirmerId], references: [id])
  employee     Employee           @relation("leave_requests_employee_idToemployees", fields: [employeeId], references: [id])

  @@index([approverId])
  @@index([employeeId])
  @@index([startDate, endDate])
  @@index([status])
  @@map("leave_requests")
}

model MarketingCostAssignment {
  id              String                @id @default(uuid())
  costId          String                @map("cost_id")
  employeeId      String                @map("employee_id")
  allocatedAmount Decimal               @map("allocated_amount") @db.Decimal(15, 2)
  createdAt       DateTime              @default(now()) @map("created_at")
  cost            MarketingCampaignCost @relation(fields: [costId], references: [id], onDelete: Cascade)

  @@unique([costId, employeeId])
  @@index([employeeId])
  @@map("marketing_cost_assignments")
}

model MarketingEmployeeGroupMember {
  id         String                 @id @default(uuid())
