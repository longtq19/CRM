generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl"]
}

// Không dùng prisma-erd-generator ở đây: `prisma generate` trong Docker không có Chromium / frontend/public đúng layout.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Tổ chức (đa tổ chức). Mỗi tổ chức có một nút gốc COMPANY và cây Department/Division bên dưới.
model Organization {
  id           String       @id @default(uuid())
  code         String       @unique
  name         String
  sortOrder    Int          @default(0) @map("sort_order")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at")
  departments                 Department[]
  divisionFlowRoutingCounters DivisionFlowRoutingCounter[]

  @@map("organizations")
}

/// Bộ phận — danh mục trong module Nhân sự (lọc, hiển thị); không dùng cho luồng vận hành / cây đơn vị.
model HrDepartmentUnit {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  /// Quản lý bộ phận HR — được duyệt/từ chối đơn nghỉ phép của nhân viên cùng bộ phận (bảng employees.hr_department_unit_id).
  managerId String?  @map("manager_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  manager   Employee? @relation("HrDepartmentUnitManager", fields: [managerId], references: [id], onDelete: SetNull)
  employees Employee[]

  @@index([managerId])
  @@map("hr_department_units")
}

model Subsidiary {
  id        String     @id @default(uuid())
  code      String     @unique
  name      String
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @default(now()) @updatedAt @map("updated_at")
  employees Employee[] @relation("EmployeeToSubsidiary")

  @@map("subsidiaries")
}

model Position {
  id           String     @id @default(uuid())
  code         String     @unique
  name         String
  departmentId String     @map("department_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  employees    Employee[]
  department   Department @relation(fields: [departmentId], references: [id])

  @@index([departmentId])
  @@map("positions")
}

model Department {
  id   String @id @default(uuid())
  code String
  name String

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  type     OrgType  @default(DEPARTMENT)
  function OrgFunc?

  autoDistributeCustomer   Boolean @default(true) @map("auto_distribute_customer")
  autoDistributeLead       Boolean @default(true) @map("auto_distribute_lead")
  customerDistributeMethod String  @default("ROUND_ROBIN") @map("customer_distribute_method")
  leadDistributeMethod     String  @default("ROUND_ROBIN") @map("lead_distribute_method")

  targetSalesUnitId    String?      @map("target_sales_unit_id")
  targetCsUnitId       String?      @map("target_cs_unit_id")
  targetSalesUnit      Department?  @relation("DepartmentToSales", fields: [targetSalesUnitId], references: [id])
  targetCsUnit         Department?  @relation("DepartmentToCS", fields: [targetCsUnitId], references: [id])
  sourceMarketingUnits Department[] @relation("DepartmentToSales")
  sourceSalesUnits     Department[] @relation("DepartmentToCS")

  parentId     String?  @map("parent_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  managerId    String?  @map("manager_id")
  displayOrder Int      @default(0) @map("display_order")

  manager             Employee?               @relation("DepartmentManager", fields: [managerId], references: [id])
  parent              Department?             @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children            Department[]            @relation("DepartmentHierarchy")
  /// Luồng phân data trong khối (JSON): marketingToSalesPct, marketingToSalesChildDivisionPct, salesToCsPct, salesToCsChildDivisionPct, csOnlyPct; externalMarketingToSalesPct lưu trên khối nhận (Sales) — chỉ dùng khi type = DIVISION
  dataFlowShares           Json?       @map("data_flow_shares")
  externalCsDivisionId     String?     @map("external_cs_division_id")
  externalCsDivision       Department? @relation("DivisionExternalCsFlow", fields: [externalCsDivisionId], references: [id], onDelete: SetNull)
  divisionsUsingExternalCs Department[] @relation("DivisionExternalCsFlow")
  /// Khối đồng cấp có đơn vị Sales khi khối này không có Sales (tương tự external CS).
  externalSalesDivisionId     String?     @map("external_sales_division_id")
  externalSalesDivision       Department? @relation("DivisionExternalSalesFlow", fields: [externalSalesDivisionId], references: [id], onDelete: SetNull)
  divisionsUsingExternalSales Department[] @relation("DivisionExternalSalesFlow")
  documentPermissions DocumentPermission[]
  employees           Employee[]
  leadAssignmentsFrom LeadAssignment[]        @relation("LeadAssignmentFromDepartment")
  leadAssignmentsTo   LeadAssignment[]        @relation("LeadAssignmentToDepartment")
  positions           Position[]
  distributionRatios  TeamDistributionRatio[]
  salesTargets        SalesTarget[]
  /// Bộ đếm phân nhánh luồng data — scope = khối cho (nơi cấu hình tỉ lệ), không phải khối nhận.
  divisionFlowRoutingCounters DivisionFlowRoutingCounter[] @relation("DivisionFlowRoutingScope")

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("departments")
}

/// Đếm số lần đã phân vào từng nhánh (target) theo khối cấu hình `scopeDivisionId` (khối cho).
/// Dùng để cân bằng tỉ lệ theo thời gian khi mỗi lead được gán ngay lập tức.
model DivisionFlowRoutingCounter {
  id              String       @id @default(uuid())
  organizationId  String       @map("organization_id")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Khối nơi lưu `data_flow_shares` quyết định tỉ lệ phân nhánh đi ra (khối cho).
  scopeDivisionId String       @map("scope_division_id")
  scopeDivision   Department   @relation("DivisionFlowRoutingScope", fields: [scopeDivisionId], references: [id], onDelete: Cascade)
  /// Ví dụ: MKT_SALES_CHILD_DIV, MKT_SALES_LEAF, EXT_MKT_SALES_LEAF, …
  kind            String
  /// Id khối con hoặc đơn vị lá đích tương ứng map trong JSON.
  targetId        String       @map("target_id")
  assignedCount   Int          @default(0) @map("assigned_count")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@unique([scopeDivisionId, kind, targetId])
  @@index([organizationId])
  @@index([scopeDivisionId, kind])
  @@map("division_flow_routing_counters")
}

model RoleGroup {
  id                  String               @id @default(uuid())
  name                String
  code                String               @unique
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  sortOrder           Int                  @default(0) @map("sort_order")
  documentPermissions DocumentPermission[]
  employees           Employee[]
  menus               Menu[]               @relation("RoleMenu")
  permissions         Permission[]         @relation("RolePermission")
  viewScopes          RoleGroupViewScope[]

  @@map("role_groups")
}

/// Phạm vi xem: áp dụng cho module Nhân sự (HR) và module liên quan khách hàng (Customer, Sales, Marketing, v.v.)
/// SELF_RECURSIVE: Chỉ bản thân / khách của mình. Cấp trên trực tiếp/gián tiếp xem được cấp dưới.
/// DEPARTMENT: Xem toàn bộ trong cùng phòng ban.
/// DIVISION: Xem toàn bộ trong cùng khối.
/// COMPANY: Toàn công ty.
model RoleGroupViewScope {
  id          String    @id @default(uuid())
  roleGroupId String    @map("role_group_id")
  context     String // HR | CUSTOMER
  scope       String // SELF_RECURSIVE | DEPARTMENT | DIVISION | COMPANY
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  roleGroup   RoleGroup @relation(fields: [roleGroupId], references: [id], onDelete: Cascade)

  @@unique([roleGroupId, context])
  @@index([roleGroupId])
  @@map("role_group_view_scopes")
}

model Menu {
  id         String      @id @default(uuid())
  label      String
  path       String
  icon       String?
  parentId   String?     @map("parent_id")
  order      Int         @default(0)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  parent     Menu?       @relation("MenuHierarchy", fields: [parentId], references: [id])
  children   Menu[]      @relation("MenuHierarchy")
  roleGroups RoleGroup[] @relation("RoleMenu")

  @@map("menus")
}

model Permission {
  id          String      @id @default(uuid())
  code        String      @unique
  name        String
  description String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  roleGroups  RoleGroup[] @relation("RolePermission")

  @@map("permissions")
}

model SystemLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  userName  String   @map("user_name")
  userPhone String?  @map("user_phone")
  action    String
  object    String
  objectId  String?  @map("object_id")
  result    String
  details   String?
  oldValues Json?    @map("old_values")
  newValues Json?    @map("new_values")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([object])
  @@index([timestamp])
  @@index([action, timestamp])
  @@index([userId, timestamp])
  @@index([object, timestamp])
  // Bổ sung: lọc nhật ký theo user/đối tượng/kết quả + tra theo bản ghi nghiệp vụ
  @@index([objectId])
  @@index([userName])
  @@index([result])
  @@index([object, objectId])
  @@map("system_logs")
}

model Bank {
  id        String                @id @default(uuid())
  code      String                @unique
  name      String
  shortName String?               @map("short_name")
  createdAt DateTime              @default(now()) @map("created_at")
  updatedAt DateTime              @updatedAt @map("updated_at")
  accounts  EmployeeBankAccount[]

  @@map("banks")
}

model EmploymentType {
  id          String     @id @default(uuid())
  code        String     @unique
  name        String
  description String?
  sortOrder   Int        @default(0) @map("sort_order")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  employees   Employee[]

  @@map("employment_types")
}

model EmployeeStatus {
  id          String     @id @default(uuid())
  code        String     @unique
  name        String
  description String?
  sortOrder   Int        @default(0) @map("sort_order")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  employees   Employee[]

  @@map("employee_statuses")
}

/// Loại nhân viên (phân theo chức năng: Marketing, Sales, CSKH, Kế toán, HR, IT, ...). Dùng cho báo cáo, lọc, hạch toán.
model EmployeeType {
  id          String     @id @default(uuid())
  code        String     @unique
  name        String
  description String?
  sortOrder   Int        @default(0) @map("sort_order")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  employees   Employee[]

  @@map("employee_types")
}

model EmployeeBankAccount {
  id            String   @id @default(uuid())
  employeeId    String   @map("employee_id")
  bankId        String   @map("bank_id")
  accountNumber String   @map("account_number")
  accountHolder String   @map("account_holder")
  isPrimary     Boolean  @default(false) @map("is_primary")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  bank          Bank     @relation(fields: [bankId], references: [id])
  employee      Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([bankId])
  @@map("employee_bank_accounts")
}

model EmployeeVehicle {
  id           String   @id @default(uuid())
  employeeId   String   @map("employee_id")
  type         String
  name         String?
  color        String?
  licensePlate String   @unique @map("license_plate")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  employee     Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("employee_vehicles")
}

model Employee {
  id                         String                @id @default(uuid())
  code                       String                @unique @map("code")
  fullName                   String                @map("full_name")
  gender                     String
  dateOfBirth                DateTime?             @map("date_of_birth")
  avatarUrl                  String?               @map("avatar_url")
  phone                      String?
  phoneHash                  String?               @map("phone_hash")
  emailCompany               String?               @map("email_company")
  emailPersonal              String?               @map("email_personal")
  passwordHash               String?               @map("password_hash")
  filePath                   String?               @map("file_path")
  address                    String?               @map("address")
  employmentTypeId           String                @map("employment_type_id")
  statusId                   String                @map("status_id")
  // Đơn vị / chức danh vận hành: nullable — HR tạo hồ sơ, Vận hành gán sau.
  positionId                 String?               @map("position_id")
  departmentId               String?               @map("department_id")
  hrDepartmentUnitId         String                @map("hr_department_unit_id")
  /// Chức danh nội bộ phục vụ quản trị HR, không tham gia logic vận hành.
  hrJobTitle                 String?               @map("hr_job_title")
  roleGroupId                String?               @map("role_group_id")
  employeeTypeId             String?               @map("employee_type_id")
  isOnline                   Boolean               @default(false) @map("is_online")
  lastActiveAt               DateTime?             @map("last_active_at")
  lastLoginAt                DateTime?             @map("last_login_at")
  isLocked                   Boolean               @default(false) @map("is_locked")
  sessionInvalidatedAt       DateTime?             @map("session_invalidated_at")
  createdAt                  DateTime              @default(now()) @map("created_at")
  updatedAt                  DateTime              @updatedAt @map("updated_at")
  id_card_back_image         String?
  id_card_front_image        String?
  id_card_issued_date        DateTime?
  id_card_issued_place       String?
  id_card_number             String?
  personalTaxCode            String?               @map("personal_tax_code")
  salesType                  String?               @map("sales_type")
  contractReminderDaysBefore Int?                  @map("contract_reminder_days_before")
  contractReminderRepeatDays Int?                  @map("contract_reminder_repeat_days")
  /// Ngày hiệu lực hợp đồng lao động (tùy chọn, mọi loại HĐ).
  contractEffectiveDate      DateTime?             @map("contract_effective_date")
  /// Ngày hết hạn hợp đồng nếu có (tùy chọn).
  contractEndDate            DateTime?             @map("contract_end_date")
  probationStartDate         DateTime?             @map("probation_start_date")
  probationEndDate           DateTime?             @map("probation_end_date")
  probationStatus            ProbationStatus?      @default(NONE) @map("probation_status")
  notifyOnNewContractUpload  Boolean?              @default(true) @map("notify_on_new_contract_upload")
  chatMemberRequestsSent     ChatMemberRequest[]   @relation("ChatMemberRequestRequester")
  chatMemberRequestsTarget   ChatMemberRequest[]   @relation("ChatMemberRequestTarget")
  chatMemberships            ChatMember[]
  sentMessages               ChatMessage[]
  readMessages               ChatReadStatus[]
  contracts                  Contract[]
  hrReminders                HrReminder[]
  interactions               CustomerInteraction[]
  marketingCustomerContributions CustomerMarketingContributor[]
  customers                  Customer[]
  marketingCustomers         Customer[]            @relation("MarketingOwnerCustomers")
  assignedLeads              DataPool[]            @relation("DataPoolAssignee")
  managedDepartments         Department[]          @relation("DepartmentManager")
  managedHrDepartmentUnits   HrDepartmentUnit[]    @relation("HrDepartmentUnitManager")

  documentPermissions      DocumentPermission[]
  ownedDocuments           Document[]                @relation("DocumentOwner")
  createdDraftInvoices     DraftInvoice[]            @relation("DraftInvoiceCreator")
  bankAccounts             EmployeeBankAccount[]
  vehicles                 EmployeeVehicle[]
  department               Department?               @relation(fields: [departmentId], references: [id])
  hrDepartmentUnit         HrDepartmentUnit        @relation(fields: [hrDepartmentUnitId], references: [id])
  employmentType           EmploymentType            @relation(fields: [employmentTypeId], references: [id])
  position                 Position?                  @relation(fields: [positionId], references: [id])
  roleGroup                RoleGroup?                @relation(fields: [roleGroupId], references: [id])
  employeeType             EmployeeType?             @relation(fields: [employeeTypeId], references: [id])
  status                   EmployeeStatus            @relation(fields: [statusId], references: [id])
  leadAssignments          LeadAssignment[]          @relation("EmployeeLeadAssignments")
  leadOpportunities        LeadOpportunity[]         @relation("EmployeeLeadOpportunities")
  leaveRequestsAsApprover  LeaveRequest[]            @relation("leave_requests_approver_idToemployees")
  leaveRequestsAsConfirmer LeaveRequest[]            @relation("leave_requests_confirmer_idToemployees")
  leaveRequests            LeaveRequest[]            @relation("leave_requests_employee_idToemployees")
  performedMaintenances    MaintenanceLog[]
  createdMarketingCosts    MarketingCampaignCost[]
  campaignMemberships      MarketingCampaignMember[] @relation("CampaignMembersEmployee")
  createdCampaigns         MarketingCampaign[]       @relation("EmployeeCreatedCampaigns")
  orders                   Order[]
  approvedPayrolls         Payroll[]                 @relation("PayrollApprover")
  createdPayrolls          Payroll[]                 @relation("PayrollCreator")
  payrolls                 Payroll[]
  userNotifications        UserNotification[]
  assignedWarranties       WarrantyClaim[]
  subsidiaries             Subsidiary[]              @relation("EmployeeToSubsidiary")
  ticketsCreated           SupportTicket[]           @relation("TicketCreator")
  ticketsAssigned          SupportTicket[]           @relation("TicketAssignee")
  pushSubscriptions        PushSubscription[]

  @@index([code])
  @@index([phone])
  @@index([phoneHash])
  @@index([fullName])
  @@index([emailCompany])
  @@index([departmentId])
  @@index([hrDepartmentUnitId])
  @@index([statusId])
  @@index([roleGroupId])
  @@index([employeeTypeId])
  @@map("employees")
}

model InternalNote {
  id         String   @id @default(uuid())
  authorId   String   @map("author_id")
  authorName String   @map("author_name")
  content    String
  date       DateTime @default(now())
  relatedTo  String   @map("related_to")
  customerId String?  @map("customer_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([authorId])
  @@index([customerId])
  @@index([date])
  @@map("internal_notes")
}

model Notification {
  id          String             @id @default(uuid())
  code        String?            @unique
  title       String
  content     String
  type        String
  targetType  String             @map("target_type")
  targetValue String?            @map("target_value")
  status      String
  ctaLabel    String?            @map("cta_label")
  ctaUrl      String?            @map("cta_url")
  scheduledAt DateTime?          @map("scheduled_at")
  sentAt      DateTime?          @map("sent_at")
  createdBy   String             @map("created_by")
  sentCount   Int                @default(0) @map("sent_count")
  readCount   Int                @default(0) @map("read_count")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  reads       NotificationRead[]

  @@map("notifications")
}

model NotificationRead {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  notificationId String       @map("notification_id")
  readAt         DateTime     @default(now()) @map("read_at")
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@map("notification_reads")
}

model UserNotification {
  id         String    @id @default(uuid())
  employeeId String    @map("employee_id")
  title      String
  content    String
  type       String
  link       String?
  metadata   Json?
  isRead     Boolean   @default(false) @map("is_read")
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  category   String    @default("GENERAL")
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, isRead])
  @@index([employeeId, createdAt])
  @@index([category])
  @@index([type])
  @@map("user_notifications")
}

/// Đăng ký Web Push cho nhân viên (hiển thị thông báo khi màn hình khóa / app nền)
model PushSubscription {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  endpoint   String   @unique
  p256dh     String   @map("p256dh")
  auth       String
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("push_subscriptions")
}

model DocumentPermission {
  id           String      @id @default(uuid())
  documentId   String      @map("document_id")
  employeeId   String?     @map("employee_id")
  departmentId String?     @map("department_id")
  roleGroupId  String?     @map("role_group_id")
  accessLevel  String      @map("access_level")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  document     Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  employee     Employee?   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  roleGroup    RoleGroup?  @relation(fields: [roleGroupId], references: [id], onDelete: Cascade)

  @@map("document_permissions")
}

model Document {
  id          String               @id @default(uuid())
  code        String               @unique
  name        String
  content     String?
  path        String
  type        String
  category    String?
  size        String?
  uploadDate  DateTime             @map("upload_date")
  uploadedBy  String               @map("uploaded_by")
  tags        String?
  version     String?
  status      String?
  ownerId     String?              @map("owner_id")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  permissions DocumentPermission[]
  owner       Employee?            @relation("DocumentOwner", fields: [ownerId], references: [id])

  @@map("documents")
}

model Customer {
  id                    String                  @id @default(uuid())
  code                  String                  @unique @default(cuid())
  name                  String?
  phone                 String
  /// SĐT phụ (tối đa 1); gán một lần, không sửa sau khi đã có.
  phoneSecondary        String?                 @unique @map("phone_secondary")
  email                 String?
  address               String?
  dateOfBirth           DateTime?               @map("date_of_birth")
  gender                String?
  provinceId            String?                 @map("province_id")
  employeeId            String?                 @map("employee_id")
  marketingOwnerId      String?                 @map("marketing_owner_id")
  attributionExpiredAt  DateTime?               @map("attribution_expired_at")
  marketingAttributionExtraDays Int?            @map("marketing_attribution_extra_days")
  spendingRankCode      String?                 @map("spending_rank_code")
  regionRankCode        String?                 @map("region_rank_code")
  leadSourceId          String?                 @map("lead_source_id")
  campaignId            String?                 @map("campaign_id")
  leadStatus            String?                 @map("lead_status")
  isValidLead           Boolean                 @default(true) @map("is_valid_lead")
  invalidReason         String?                 @map("invalid_reason")
  duplicateOfCustomerId String?                 @map("duplicate_of_customer_id")
  status                Status                  @default(ACTIVE)
  totalOrdersValue      Float                   @default(0) @map("total_orders_value")
  joinedDate            DateTime                @default(now()) @map("joined_date")
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")
  bankAccount           String?                 @map("bank_account")
  bankName              String?                 @map("bank_name")
  businessType          String?                 @map("business_type")
  createdById           String?                 @map("created_by_id")
  createdByRole         String?                 @map("created_by_role")
  districtId            String?                 @map("district_id")
  farmArea              Float?                  @map("farm_area")
  farmAreaUnit          String?                 @map("farm_area_unit")
  farmName              String?                 @map("farm_name")
  farmingMethod         String?                 @map("farming_method")
  farmingYears          Int?                    @map("farming_years")
  irrigationType        String?                 @map("irrigation_type")
  lastOrderAt           DateTime?               @map("last_order_at")
  mainCrops             String[]                @map("main_crops")
  // Mapping crop -> number of roots for crops that are counted "per root".
  // Stored as JSONB, e.g. { "Cà phê": 100, "Điều": 50 }
  mainCropsRootCounts  Json?                   @map("main_crops_root_counts")
  note                  String?
  salesChannel          String?                 @map("sales_channel")
  salesChannelNote      String?                 @map("sales_channel_note")
  soilType              String?                 @map("soil_type")
  taxCode               String?                 @map("tax_code")
  totalOrders           Int                     @default(0) @map("total_orders")
  wardId                String?                 @map("ward_id")
  addressRecord         CustomerAddress?
  aggregate             CustomerAggregate?
  farms                 CustomerFarm[]
  interactions          CustomerInteraction[]
  marketingContributors CustomerMarketingContributor[]
  tags                  CustomerTagAssignment[]
  campaign              MarketingCampaign?      @relation(fields: [campaignId], references: [id])
  district              District?               @relation("CustomerDistrict", fields: [districtId], references: [id])
  duplicateOfCustomer   Customer?               @relation("CustomerDuplicate", fields: [duplicateOfCustomerId], references: [id])
  duplicates            Customer[]              @relation("CustomerDuplicate")
  employee              Employee?               @relation(fields: [employeeId], references: [id])
  leadSource            MarketingSource?        @relation(fields: [leadSourceId], references: [id])
  marketingOwner        Employee?               @relation("MarketingOwnerCustomers", fields: [marketingOwnerId], references: [id])
  province              Province?               @relation(fields: [provinceId], references: [id])
  regionRank            CustomerRegionRank?     @relation(fields: [regionRankCode], references: [code])
  spendingRank          CustomerSpendingRank?   @relation(fields: [spendingRankCode], references: [code])
  statusId              String?                 @map("status_id")
  customerStatus        CustomerStatus?         @relation(fields: [statusId], references: [id])
  ward                  Ward?                   @relation("CustomerWard", fields: [wardId], references: [id])
  dataPool              DataPool?
  draftInvoices         DraftInvoice[]
  assignments           LeadAssignment[]
  opportunities         LeadOpportunity[]
  orders                Order[]
  warrantyClaims        WarrantyClaim[]

  @@index([employeeId])
  @@index([marketingOwnerId])
  @@index([provinceId])
  @@index([districtId])
  @@index([wardId])
  @@index([spendingRankCode])
  @@index([statusId])
  @@index([phone])
  @@index([phoneSecondary])
  @@index([leadStatus])
  @@index([createdByRole])
  @@index([joinedDate])
  @@index([status])
  // Hiệu năng: danh sách sort theo updatedAt; thống kê theo createdAt; phạm vi OR createdById; campaign / lọc cây trồng
  @@index([updatedAt])
  @@index([createdAt])
  @@index([createdById])
  @@index([campaignId])
  @@index([status, updatedAt])
  @@index([mainCrops], type: Gin)
  @@map("customers")
}

model CustomerTag {
  id          String                  @id @default(uuid())
  code        String                  @unique
  name        String
  color       String                  @default("#3B82F6")
  bgColor     String?                 @map("bg_color")
  description String?
  category    String?
  sortOrder   Int                     @default(0) @map("sort_order")
  isActive    Boolean                 @default(true) @map("is_active")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")
  assignments CustomerTagAssignment[]

  @@map("customer_tags")
}

model CustomerTagAssignment {
  id         String      @id @default(uuid())
  customerId String      @map("customer_id")
  tagId      String      @map("tag_id")
  assignedBy String?     @map("assigned_by")
  assignedAt DateTime    @default(now()) @map("assigned_at")
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag        CustomerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([customerId, tagId])
  @@index([customerId])
  @@index([tagId])
  @@map("customer_tag_assignments")
}

model CustomerFarm {
  id             String   @id @default(uuid())
  customerId     String   @map("customer_id")
  name           String
  area           Float?
  areaUnit       String?  @map("area_unit")
  address        String?
  wardId         String?  @map("ward_id")
  districtId     String?  @map("district_id")
  provinceId     String?  @map("province_id")
  coordinates    String?
  crops          String[]
  soilType       String?  @map("soil_type")
  irrigationType String?  @map("irrigation_type")
  farmingMethod  String?  @map("farming_method")
  hasIoTDevice   Boolean  @default(false) @map("has_iot_device")
  iotDeviceIds   String[] @map("iot_device_ids")
