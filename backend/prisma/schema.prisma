  type       AddressType
  detail     String
  wardId     String      @map("ward_id")
  districtId String?     @map("district_id")
  provinceId String      @map("province_id")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  customer   Customer    @relation(fields: [customerId], references: [id])
  district   District?   @relation(fields: [districtId], references: [id])
  province   Province    @relation(fields: [provinceId], references: [id])
  ward       Ward        @relation(fields: [wardId], references: [id])

  @@index([provinceId])
  @@map("customer_addresses")
}

model Province {
  id                String               @id @default(uuid())
  code              String               @unique
  name              String
  customerAddresses CustomerAddress[]
  regionRanks       CustomerRegionRank[]
  customers         Customer[]
  districts         District[]
  wards             Ward[]
  warehouses        Warehouse[]

  @@map("provinces")
}

model District {
  id                String            @id @default(uuid())
  code              String            @unique
  name              String
  provinceId        String            @map("province_id")
  customerAddresses CustomerAddress[]
  customers         Customer[]        @relation("CustomerDistrict")
  province          Province          @relation(fields: [provinceId], references: [id])
  wards             Ward[]
  warehouses        Warehouse[]

  @@index([provinceId])
  @@map("districts")
}

model Ward {
  id                String            @id @default(uuid())
  code              String            @unique
  name              String
  provinceId        String            @map("province_id")
  districtId        String?           @map("district_id")
  customerAddresses CustomerAddress[]
  customers         Customer[]        @relation("CustomerWard")
  district          District?         @relation(fields: [districtId], references: [id])
  province          Province          @relation(fields: [provinceId], references: [id])
  warehouses        Warehouse[]

  @@index([provinceId])
  @@map("wards")
}

model Order {
  id                 String             @default(uuid())
  code               String
  customerId         String             @map("customer_id")
  employeeId         String?            @map("employee_id")
  orderDate          DateTime           @map("order_date")
  totalAmount        Decimal            @map("total_amount") @db.Decimal(15, 2)
  discount           Decimal            @default(0) @db.Decimal(15, 2)
  finalAmount        Decimal            @map("final_amount") @db.Decimal(15, 2)
  paymentStatus      String             @map("payment_status")
  orderStatus        String             @map("order_status")
  createdAt          DateTime           @default(now()) @map("created_at")
  confirmedAt        DateTime?          @map("confirmed_at")
  confirmedById      String?            @map("confirmed_by_id")
  deliveredAt        DateTime?          @map("delivered_at")
  note               String?
  receiverAddress    String?            @map("receiver_address")
  receiverDistrict   String?            @map("receiver_district")
  receiverName       String?            @map("receiver_name")
  receiverPhone      String?            @map("receiver_phone")
  receiverProvince   String?            @map("receiver_province")
  receiverWard       String?            @map("receiver_ward")
  receiverProvinceId Int?               @map("receiver_province_id")
  receiverDistrictId Int?               @map("receiver_district_id")
  receiverWardId     Int?               @map("receiver_ward_id")
  shippedAt          DateTime?          @map("shipped_at")
  shippingFee        Decimal?           @map("shipping_fee") @db.Decimal(15, 2)
  shippingProvider   String?            @map("shipping_provider")
  trackingNumber     String?            @map("tracking_number")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  codAmount          Decimal?           @map("cod_amount") @db.Decimal(15, 2)
  shippingCode       String?            @map("shipping_code")
  shippingStatus     String             @default("PENDING") @map("shipping_status")
  editHistory        Json?              @map("edit_history")
  isFirstOrder       Boolean            @default(true) @map("is_first_order")
  last_edited_at     DateTime?
  lastEditedById     String?            @map("last_edited_by_id")
  resalesEmployeeId  String?            @map("resales_employee_id")
  revenueCountedAt   DateTime?          @map("revenue_counted_at")
  salesEmployeeId    String?            @map("sales_employee_id")
  items              OrderItem[]
  orderShippingLogs  OrderShippingLog[]
  customer           Customer           @relation(fields: [customerId], references: [id])
  employee           Employee?          @relation(fields: [employeeId], references: [id])

  @@id([id, orderDate])
  @@unique([code, orderDate])
  @@index([customerId, orderDate])
  @@index([orderDate])
  @@index([shippingStatus])
  @@index([shippingCode])
  @@index([shippingStatus, deliveredAt])
  @@index([employeeId])
  // Danh sách / thống kê: lọc theo trạng thái + khoảng ngày; nhân viên + ngày; orderStatus
  @@index([shippingStatus, orderDate])
  @@index([employeeId, orderDate])
  @@index([orderStatus])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  code       String   @unique
  orderId    String   @map("order_id")
  orderDate  DateTime @map("order_date")
  productId  String   @map("product_id")
  quantity   Int
  unitPrice  Decimal  @map("unit_price") @db.Decimal(15, 2)
  totalPrice Decimal  @map("total_price") @db.Decimal(15, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  order      Order    @relation(fields: [orderId, orderDate], references: [id, orderDate], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([orderId, orderDate])
  @@index([productId])
  @@map("order_items")
}

model CustomerInteraction {
  id           String    @default(uuid())
  code         String
  customerId   String    @map("customer_id")
  employeeId   String    @map("employee_id")
  type         String
  content      String
  /// USER_NOTE | SYSTEM_CHANGE
  kind         String    @default("USER_NOTE") @map("kind")
  /// Chi tiết tương tác (form mới); có thể validate min ký tự theo min_note_characters.
  detail       String?   @map("detail") @db.Text
  /// Trạng thái xử lý Sales snapshot khi tạo bản ghi thủ công.
  processingStatusAtTime String? @map("processing_status_at_time")
  nextActionAt DateTime? @map("next_action_at")
  result       String?
  createdAt    DateTime  @default(now()) @map("created_at")
  customer     Customer  @relation(fields: [customerId], references: [id])
  employee     Employee  @relation(fields: [employeeId], references: [id])

  @@id([id, createdAt])
  @@unique([code, createdAt])
  @@index([customerId, createdAt])
  @@index([employeeId])
  @@index([nextActionAt])
  @@index([kind])
  @@map("customer_interactions")
}

/// NV Marketing từng ghi nhận / nhập SĐT liên quan tới khách (1-n).
model CustomerMarketingContributor {
  id                 String   @id @default(uuid())
  customerId         String   @map("customer_id")
  employeeId         String   @map("employee_id")
  firstContributedAt DateTime @default(now()) @map("first_contributed_at")
  customer           Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  employee           Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([customerId, employeeId])
  @@index([customerId])
  @@index([employeeId])
  @@map("customer_marketing_contributors")
}

model CustomerAggregate {
  id             String    @id @default(uuid())
  code           String    @unique
  customerId     String    @unique @map("customer_id")
  totalOrders    Int       @default(0) @map("total_orders")
  totalSpent     Decimal   @default(0) @map("total_spent") @db.Decimal(15, 2)
  lastOrderAt    DateTime? @map("last_order_at")
  periodSpent    Decimal   @default(0) @map("period_spent") @db.Decimal(15, 2)
  salesRevenue   Float     @default(0) @map("sales_revenue")
  resalesRevenue Float     @default(0) @map("resales_revenue")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  customer       Customer  @relation(fields: [customerId], references: [id])

  @@index([totalSpent])
  @@map("customer_aggregates")
}

model CustomerSpendingRank {
