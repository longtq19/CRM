  @@index([status])
  @@index([endDate])
  @@map("contracts")
}

model ChatGroup {
  id              String              @id @default(uuid())
  name            String
  type            String              @default("GROUP")
  avatarUrl       String?             @map("avatar_url")
  backgroundColor String?             @map("background_color")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  memberRequests  ChatMemberRequest[]
  members         ChatMember[]
  messages        ChatMessage[]

  @@map("chat_groups")
}

model ChatMember {
  id                String    @id @default(uuid())
  groupId           String    @map("group_id")
  employeeId        String    @map("employee_id")
  role              String    @default("MEMBER")
  nickname          String?   @map("nickname")
  joinedAt          DateTime  @default(now()) @map("joined_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")
  lastReadMessageId String?   @map("last_read_message_id")
  backgroundColor   String?   @map("background_color")
  isPinned          Boolean   @default(false) @map("is_pinned")
  pinnedAt          DateTime? @map("pinned_at")
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  group             ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, employeeId])
  @@map("chat_members")
}

model ChatMemberRequest {
  id               String    @id @default(uuid())
  groupId          String    @map("group_id")
  requesterId      String    @map("requester_id")
  targetEmployeeId String    @map("target_employee_id")
  status           String    @default("PENDING") @map("status")
  createdAt        DateTime  @default(now()) @map("created_at")
  group            ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  requester        Employee  @relation("ChatMemberRequestRequester", fields: [requesterId], references: [id])
  targetEmployee   Employee  @relation("ChatMemberRequestTarget", fields: [targetEmployeeId], references: [id])

  @@index([groupId])
  @@index([requesterId])
  @@index([targetEmployeeId])
  @@map("chat_member_requests")
}

model ChatMessage {
  id          String           @id @default(uuid())
  groupId     String           @map("group_id")
  senderId    String           @map("sender_id")
  content     String?
  type        String           @default("TEXT")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  attachments ChatAttachment[]
  group       ChatGroup        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender      Employee         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  readStatus  ChatReadStatus[]

  @@index([groupId, createdAt])
  @@index([senderId])
  @@map("chat_messages")
}

model ChatAttachment {
  id        String      @id @default(uuid())
  messageId String      @map("message_id")
  fileUrl   String      @map("file_url")
  fileName  String      @map("file_name")
  fileSize  Int         @map("file_size")
  fileType  String      @map("file_type")
  createdAt DateTime    @default(now()) @map("created_at")
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("chat_attachments")
}

model ChatReadStatus {
  id        String      @id @default(uuid())
  messageId String      @map("message_id")
  userId    String      @map("user_id")
  readAt    DateTime    @default(now()) @map("read_at")
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      Employee    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@map("chat_read_statuses")
}

model CustomerAddress {
