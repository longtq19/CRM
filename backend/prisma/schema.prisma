model DataPool {
  id                  String         @id @default(uuid())
  customerId          String         @unique @map("customer_id")
  source              DataPoolSource @default(MARKETING)
  enteredAt           DateTime       @default(now()) @map("entered_at")
  assignedAt          DateTime?      @map("assigned_at")
  assignedToId        String?        @map("assigned_to_id")
  status              DataPoolStatus @default(AVAILABLE)
  priority            Int            @default(0)
  note                String?
  poolType            String         @default("SALES") @map("pool_type")
  // 1: chăm sóc khách hàng lần 1; 2: chăm sóc khách hàng lần 2 (đi vòng đời theo tham số vận hành)
  cskhStage           Int            @default(1) @map("cskh_stage")
  roundCount          Int            @default(0) @map("round_count")
  maxRounds           Int            @default(5) @map("max_rounds")
  previousAssignees   String[]       @default([]) @map("previous_assignees")
  deadline            DateTime?
  holdUntil           DateTime?      @map("hold_until")
  interactionDeadline DateTime?      @map("interaction_deadline")
  customDeadline      DateTime?      @map("custom_deadline")
  /// true: Sales đang xử lý sau khi CSKH thu hồi; hết hạn Sales → ưu tiên phân lại CSKH (không tính vòng Sales).
  awaitingSalesAfterCskh Boolean   @default(false) @map("awaiting_sales_after_cskh")
  processingStatus    String?        @map("processing_status")
  /// SALES_OPEN: kho Sales chưa gán; FLOATING: kho thả nổi (theo pool_push_processing_statuses).
  poolQueue           String         @default("SALES_OPEN") @map("pool_queue")
  /// Thời điểm hẹn gọi lại khách (Sales/CSKH).
  callbackAt                DateTime? @map("callback_at")
  /// Bật gửi thông báo nhắc gọi lại cho NV được gán.
  callbackNotifyEnabled     Boolean   @default(false) @map("callback_notify_enabled")
  /// Nhắc trước bao nhiêu phút so với `callbackAt` (0 = đúng giờ hẹn).
  callbackNotifyMinutesBefore Int?    @map("callback_notify_minutes_before")
  /// Đã gửi nhắc lần tương ứng với lượt hẹn hiện tại (reset khi đổi hẹn/cấu hình nhắc).
  callbackReminderSentAt    DateTime? @map("callback_reminder_sent_at")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  assignedTo          Employee?      @relation("DataPoolAssignee", fields: [assignedToId], references: [id])
  customer            Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([assignedToId])
  @@index([enteredAt])
  @@index([poolType])
  @@index([poolQueue])
  @@index([callbackAt, callbackNotifyEnabled])
  @@map("data_pool")
}

