  name      String
  minAmount Decimal    @map("min_amount") @db.Decimal(15, 2)
  maxAmount Decimal    @map("max_amount") @db.Decimal(15, 2)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  bgColor   String?    @map("bg_color")
  color     String     @default("#3B82F6")
  sortOrder Int        @default(0) @map("sort_order")
  customers Customer[]

  @@map("customer_spending_ranks")
}

model CustomerRegionRank {
  id         String     @id @default(uuid())
  code       String     @unique
  name       String
  provinceId String?    @map("province_id")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  province   Province?  @relation(fields: [provinceId], references: [id])
  customers  Customer[]

  @@map("customer_region_ranks")
}

model CustomerRankSetting {
  id            String   @id @default(uuid())
  code          String   @unique
  rankingPeriod Int      @map("ranking_period")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("customer_rank_settings")
}

model MarketingSource {
  id          String                  @id @default(uuid())
  code        String                  @unique
  name        String
  description String?
  isActive    Boolean                 @default(true) @map("is_active")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")
  customers   Customer[]
  costs       MarketingCampaignCost[]
  campaigns   MarketingCampaign[]

  @@map("marketing_sources")
}

model MarketingCampaign {
  id                  String                     @id @default(uuid())
  code                String                     @unique
  name                String
  description         String?
  status              String                     @map("status")
  startDate           DateTime                   @map("start_date")
  endDate             DateTime?                  @map("end_date")
  totalBudget         Decimal?                   @map("total_budget") @db.Decimal(15, 2)
  sourceId            String?                    @map("source_id")
  createdByEmployeeId String                     @map("created_by_employee_id")
  createdAt           DateTime                   @default(now()) @map("created_at")
  updatedAt           DateTime                   @updatedAt @map("updated_at")
  allowedOrigins      String?                    @map("allowed_origins")
  apiKey              String?                    @unique @map("api_key")
  leadCount           Int                        @default(0) @map("lead_count")
  webhookSecret       String?                    @map("webhook_secret")
  acceptedFields      Json?                      @map("accepted_fields")
  /// NONE = không nhận mã tỉnh/huyện/xã; OLD/NEW = ID thuộc danh mục trước/sau sáp nhập (khớp `AddressType` trên `customer_addresses`)
  publicLeadAddressHierarchy String              @default("NONE") @map("public_lead_address_hierarchy")
  customers           Customer[]
  opportunities       LeadOpportunity[]
  costs               MarketingCampaignCost[]
  members             MarketingCampaignMember[]
  products            MarketingCampaignProduct[]
  createdByEmployee   Employee                   @relation("EmployeeCreatedCampaigns", fields: [createdByEmployeeId], references: [id])
  source              MarketingSource?           @relation(fields: [sourceId], references: [id])

  @@index([sourceId])
  @@index([createdByEmployeeId])
  @@index([apiKey])
  @@map("marketing_campaigns")
}

model MarketingCampaignProduct {
  id         String            @id @default(uuid())
  campaignId String            @map("campaign_id")
  productId  String            @map("product_id")
  createdAt  DateTime          @default(now()) @map("created_at")
  campaign   MarketingCampaign @relation(fields: [campaignId], references: [id])
  product    Product           @relation(fields: [productId], references: [id])

  @@unique([campaignId, productId])
  @@index([campaignId])
  @@map("marketing_campaign_products")
}

model MarketingCampaignMember {
  id         String            @id @default(uuid())
  campaignId String            @map("campaign_id")
  employeeId String            @map("employee_id")
  role       String            @map("role")
  createdAt  DateTime          @default(now()) @map("created_at")
  campaign   MarketingCampaign @relation(fields: [campaignId], references: [id])
  employee   Employee          @relation("CampaignMembersEmployee", fields: [employeeId], references: [id])

  @@unique([campaignId, employeeId])
  @@index([employeeId])
  @@map("marketing_campaign_members")
}

model MarketingCampaignCost {
  id                String                    @id @default(uuid())
  campaignId        String                    @map("campaign_id")
  sourceId          String?                   @map("source_id")
  costDate          DateTime                  @map("cost_date")
  amount            Decimal                   @map("amount") @db.Decimal(15, 2)
  description       String?                   @map("description")
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")
  adAccountId       String?                   @map("ad_account_id")
  attachmentUrl     String?                   @map("attachment_url")
  clicks            Int?                      @map("clicks")
  costType          String                    @default("AD_SPEND") @map("cost_type")
  createdById       String?                   @map("created_by_id")
  impressions       Int?                      @map("impressions")
  platform          String?                   @map("platform")
  reach             Int?                      @map("reach")
  employeeGroupId   String?                   @map("employee_group_id")
  campaign          MarketingCampaign         @relation(fields: [campaignId], references: [id])
  createdBy         Employee?                 @relation(fields: [createdById], references: [id])
  employeeGroup     MarketingEmployeeGroup?   @relation(fields: [employeeGroupId], references: [id])
  source            MarketingSource?          @relation(fields: [sourceId], references: [id])
  assignedEmployees MarketingCostAssignment[]

  @@index([campaignId])
  @@index([sourceId])
  @@index([costDate])
  @@index([employeeGroupId])
